# =============================================================================
# ความลับใส่แค่บนเครื่องคุณ — ไม่ส่งให้ AI / ไม่ commit
# =============================================================================
# 1) คัดลอกไฟล์นี้เป็น `.env.local` (แนะนำ) หรือ `.env`
# 2) แก้ค่าด้านล่างให้ตรงกับ DBeaver / ที่ IT ให้มา
# 3) ทดสอบ: npm run db:ping → npm run db:migrate → npm run db:seed
# 4) (ทางเลือก) ดึงข้อมูลตัวอย่างจาก mockData เข้า DB: npm run db:seed:demo
# 5) รันแอปกับ API: npm run dev (API + Vite พร้อมกัน) หรือ npm run dev:local เหมือนกัน
#
# ลำดับโหลด: `.env` ก่อน แล้ว `.env.local` ทับ (migrate / seed / db:ping / API ใช้แบบนี้)
# ไฟล์ `.env` และ `.env.local` อยู่ใน .gitignore แล้ว
#
# โหมดท้องถิ่น: `npm run dev` (แนะนำ) หรือ `npm run api:local` + `npm run dev:vite` แยกสองเทอร์มินัล
# โหมด Vercel: Import โปรเจกต์ → Framework Preset: Vite → Root เดียวกับ repo นี้
#   Build Command: npm run build   |   Output Directory: dist   |   Install Command: npm install
#   Environment Variables (Production + Preview):
#     DATABASE_URL = connection string ไปยัง database ชื่อ car_stamp (หรือที่โฮสต์สร้างให้)
#     POSTGRES_URL = บางโฮสต์ (เช่น Vercel Postgres) ใส่แทน DATABASE_URL ได้ — API อ่านทั้งสองคีย์
#     PGSCHEMA=car_stamp
#     PG_SSL=true
#
#     >>> AUTH_JWT_SECRET (บังคับ) — ถ้าไม่ใส่บน Vercel จะ login ไม่ได้ / API คืน 503
#         Dashboard → Project → Settings → Environment Variables → เพิ่มชื่อ AUTH_JWT_SECRET
#         ค่า: สุ่มเอง อย่างน้อย 32 ตัวอักษร (ไม่ใช่ข้อความ placeholder ด้านล่าง)
#         สร้างค่าเร็ว:  PowerShell  [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
#                       หรือ       openssl rand -base64 48
#         ใส่ทั้ง Production และ Preview แล้วกด Redeploy (ถ้าเพิ่งเพิ่ม env ครั้งแรก)
#
#     VITE_DEMO_MODE=false  (บังคับถ้าต้องการ login จริงบน production)
#     AUTH_COOKIE_SAMESITE=Lax  (แนะนำเมื่อโดเมน frontend = โดเมน API บน Vercel)
#   หลัง deploy: รัน migrate + seed จากเครื่อง local ชี้ DATABASE_URL เดียวกับ production:
#     npm run db:migrate && npm run db:seed
#   สร้าง database ว่าง: scripts/sql/create-database-car-stamp.sql (รันต่อ DB postgres ด้วยสิทธิ์ CREATEDB)
#   Deploy CLI: npm run deploy:vercel
#
# --- ก่อนกด Deploy (เช็กบนเครื่อง ไม่ต้องรัน vercel deploy ก่อน) ---
#   1) รัน: npm run vercel:check   (test + tsc + vite build เหมือนบน Vercel build)
#   2) Vercel Dashboard → Project → Settings: Framework=Vite, Output=dist, Node 20+
#   3) ใส่ Environment Variables ตามบล็อกด้านบน (ทั้ง Production และ Preview ถ้าใช้) — อย่าลืม AUTH_JWT_SECRET
#   4) ฐานข้อมูล: migrate + seed ชี้ URL เดียวกับที่ใส่ใน Vercel แล้วค่อย deploy
#   5) vercel.json ตั้ง maxDuration=10 วินาที (แผน Hobby) — ถ้าใช้ Pro แล้ว query นาน แก้เป็น 60 ใน vercel.json ได้
# =============================================================================

# --- Frontend (Vite เท่านั้น — ไม่ใส่รหัส DB ตรงนี้) ---
# ใช้ Postgres + login จริง: ปิดโหมดสาธิต
# VITE_DEMO_MODE=false
#
# ข้อความ “บัญชีทดลอง” บนหน้า Login (ถ้าไม่ตั้ง จะแสดง admin@example.com / ChangeMe123! ให้ตรง db:seed)
# VITE_LOGIN_TRIAL_EMAIL=admin@example.com
# VITE_LOGIN_TRIAL_PASSWORD_HINT=ChangeMe123!
#
# ลิงก์สมัครงานบนหน้า /apply (บอร์ดประกาศ) — ถ้าไม่ตั้งจะใช้ค่าเริ่มต้นในโค้ด / หรือ VITE_SOWORK_APPLY_URL (ชื่อเก่า)
# VITE_PUBLIC_APPLY_URL=https://example.com/apply

# เข้าด้วยการเลือก Staff / Supervisor / Admin (ไม่ใช้อีเมล/รหัส) — API ใช้ user คนแรกใน DB ตาม role
# ค่าเริ่มต้น: เปิดอยู่แล้ว — ปิดเท่านั้นถ้าต้องการ: JARVIS_DEV_ROLE_LOGIN=false
# JARVIS_DEV_ROLE_LOGIN=false

# Connection string (ไม่มีช่องว่าง)
# ถ้าได้ "Invalid username/password, login denied" → user/password ใน URL ไม่ตรงกับที่ PostgreSQL รับ
# ให้ก็อปจาก DBeaver (คนละ user กับ MySQL: มักเป็น postgres ไม่ใช่ root)
# รหัสมี @ : / ? # ต้อง encode (เช่น my@pass → my%40pass)
# ชื่อ database แนะนำ: car_stamp (PostgreSQL ใช้ underscore — ไม่มีช่องว่างใน URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/car_stamp

# schema ของตารางแอป — ใช้ car_stamp (ตัวพิมพ์เล็กทั้งหมด) ให้ตรงกับ DBeaver / migration 000
# ถ้าไม่ตั้ง แอป/migrate/seed จะใช้ car_stamp เป็นค่าเริ่มต้น
# หลังตั้ง DATABASE_URL แล้วรัน: npm run db:migrate && npm run db:seed
# ตรวจว่า schema มีตาราง: npm run db:inspect
# ถ้า car_stamp ว่างแต่ระบบบันทึกว่า migrate แล้ว (ตารางไป public): npm run db:migrate:replay && npm run db:seed
PGSCHEMA=car_stamp

# เซิร์ฟเวอร์ภายนอกมักต้องเปิด SSL — ถ้าเชื่อมไม่ได้ลอง false
PG_SSL=true

# ถ้าไม่ต้องการให้ API อ่าน .env.local ทับตัวแปร (เช่น debug)
# JARVIS_SKIP_LOCAL_ENV=1

# พอร์ต API แบบท้องถิ่น (server/local-api.ts) — ต้องตรงกับ VITE_API_PROXY_TARGET ถ้าเปลี่ยน
# LOCAL_API_PORT=3000

# ถ้า vercel dev ไปที่พอร์ตอื่น (เช่น 3000 ถูกใช้แล้ว) ให้ตรงกับพอร์ตนั้น
# VITE_API_PROXY_TARGET=http://localhost:3001

# ถ้าใช้ Geocoding
# GOOGLE_MAPS_API_KEY=

# --- Auth (production / local API) ---
# จำเป็นสำหรับ login และ endpoint ที่ต้องล็อกอิน — บน Vercel ต้องตั้งใน Environment Variables (ไม่มีใน repo)
# ถ้าแอปขึ้นข้อความว่า AUTH_JWT_SECRET ไม่ได้ตั้ง → ใส่คีย์นี้บน Vercel แล้ว Redeploy
AUTH_JWT_SECRET=replace-with-long-random-secret-at-least-32-characters

# อายุ token (วินาที) — default 1800
# AUTH_TOKEN_TTL_SECONDS=1800

# ชื่อคุกกี้ (default jarvis_auth)
# AUTH_COOKIE_NAME=jarvis_auth

# Lax หรือ strict (production + HTTPS แนะนำ Lax)
# AUTH_COOKIE_SAMESITE=strict

# รหัสผ่านเริ่มต้นของผู้ใช้ที่ seed (npm run db:seed)
# SEED_USER_PASSWORD=ChangeMe123!

# (ทางเลือก) สร้าง/อัปเดต admin คนเดียว — ใส่เฉพาะใน .env.local อย่า commit
# รัน npm run db:seed หลังตั้งค่า — จะลด admin คนอื่นเป็น staff โดย default
# SEED_SOLE_ADMIN_EMAIL=
# SEED_SOLE_ADMIN_PASSWORD=
# SEED_SOLE_ADMIN_NAME=
# SEED_SOLE_ADMIN_DEMOTE_OTHERS=true

# =============================================================================
# สำเนาโปรเจกต์ (รันหลาย instance บนเครื่องเดียว / ไม่ให้ชนกับโปรเจกต์ต้นฉบับ)
# =============================================================================
# ฐานข้อมูลใหม่: สร้าง database ใหม่ใน PostgreSQL (แนะนำคนละ DATABASE) แล้วตั้ง DATABASE_URL
#   จากนั้น: npm run db:init  (หรือ db:ping → db:migrate → db:seed ตามลำดับ)
# PGSCHEMA: ใช้ชื่อ schema คนละชุดต่อ copy (เช่น car_stamp_dev) เมื่อใช้ DB เดียวกัน
#   หมายเหตุ: ตาราง public._jarvis_migrations ใช้ร่วมทั้ง database — ถ้าแชร์ DB ระหว่างสอง schema
#   ที่ migration ชื่อไฟล์เดียวกัน ระบบจะข้าม migration ชุดที่สอง ควรใช้ database แยกต่อ instance ถ้าเป็นไปได้
#
# พอร์ต Vite (หน้าเว็บ): ค่าเริ่มต้น 8080 — สำเนาที่สองตั้งเช่น
# VITE_DEV_SERVER_PORT=8091
#
# พอร์ต API ท้องถิ่น + proxy ให้ตรงกัน เช่น copy ที่สองใช้ 3001
# LOCAL_API_PORT=3001
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
#
# คุกกี้ login ต้องคนละชื่อถ้าเปิดสองแอปบน localhost เดียวกัน (ไม่งั้น session ปนกัน)
# AUTH_COOKIE_NAME=car_stamp_a_auth
#
# ชื่อใน log console ของ API (ทางเลือก)
# APP_LOG_LABEL=car-stamp-a
